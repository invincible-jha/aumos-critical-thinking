# ============================================================================
# AumOS Critical Thinking — environment variable reference
# Copy to .env and fill in real values. Never commit .env to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_DATABASE_URL=postgresql+asyncpg://aumos:changeme@localhost:5432/aumos_critical_thinking
AUMOS_CRITICAL_DATABASE_POOL_SIZE=10
AUMOS_CRITICAL_DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_CRITICAL_KAFKA_CONSUMER_GROUP=aumos-critical-thinking

# ---------------------------------------------------------------------------
# Bias detection
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_SEVERE_BIAS_THRESHOLD=0.75
AUMOS_CRITICAL_LOW_REVIEW_DURATION_SECONDS=10

# ---------------------------------------------------------------------------
# Judgment validation
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_LOW_ACCURACY_THRESHOLD=0.6
AUMOS_CRITICAL_ACCURACY_TREND_PERIODS=12

# ---------------------------------------------------------------------------
# Atrophy monitoring
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_ATROPHY_INTERVENTION_THRESHOLD=high
AUMOS_CRITICAL_ATROPHY_ASSESSMENT_RETENTION_DAYS=730

# ---------------------------------------------------------------------------
# Challenge generation (LLM)
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_LLM_MODEL_ID=claude-opus-4-6
AUMOS_CRITICAL_CHALLENGE_GENERATION_MAX_TOKENS=4096
AUMOS_CRITICAL_CHALLENGE_GENERATION_TEMPERATURE=0.7
AUMOS_CRITICAL_MAX_ACTIVE_CHALLENGES_PER_DOMAIN=50

# ---------------------------------------------------------------------------
# Training recommendations
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_MAX_MODULES_PER_PROGRAM=10
AUMOS_CRITICAL_CHALLENGE_ASSIGNMENTS_PER_RECOMMENDATION=5

# ---------------------------------------------------------------------------
# Upstream service URLs
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_GOVERNANCE_ENGINE_URL=http://aumos-governance-engine:8016
AUMOS_CRITICAL_OBSERVABILITY_URL=http://aumos-observability:8007

# ---------------------------------------------------------------------------
# HTTP client
# ---------------------------------------------------------------------------
AUMOS_CRITICAL_HTTP_TIMEOUT=30.0
AUMOS_CRITICAL_HTTP_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# AumOS platform (from aumos-common)
# ---------------------------------------------------------------------------
AUMOS_SERVICE_NAME=aumos-critical-thinking
AUMOS_ENVIRONMENT=development
AUMOS_LOG_LEVEL=INFO
AUMOS_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
